# TB_to_Tutorial_converter — environment variables
#
# Copy this file to `.env` and fill in real values.
# `.env` is gitignored (see .gitignore).
#
# Phase 0 gate (test3): all REQUIRED vars must be real values, not placeholders.
# Placeholder shapes recognized by FIX-I7 (will fail Phase 0):
#   - empty / whitespace-only
#   - <angle-bracketed>
#   - XXX+ / TODO / CHANGEME / FIXME
#   - YOUR_*_HERE / ${VAR} / "placeholder"
#   - "..." (literal ellipsis)
#   - $(...)  (command substitution literal)   ← added per DRIFT-test3-001
#
# The DRIFT-test3-001 addition closes a real foot-gun: if you copy-paste the
# SESSION_SECRET hint into a single-quoted shell, the literal "$(openssl rand
# -base64 32)" survives unevaluated and would otherwise pass a naive truthy
# guard. The validator in src/lib/env.ts now treats this shape as a placeholder.

# === REQUIRED ===

# OpenAI API key (used for chapter generation, quiz generation, flashcards)
# Get yours at: https://platform.openai.com/api-keys
# Test mode: any sk-... value (will charge real $$); for true offline test,
# stub OpenAI client via OPENAI_BASE_URL pointing at a local mock.
OPENAI_API_KEY=<your-openai-api-key-here>

# Session secret for cookie-signed session-ids (anonymous auth).
# Generate via: openssl rand -base64 32
# IMPORTANT: paste the RESULT of openssl, not the literal command.
# Wrong:  SESSION_SECRET='$(openssl rand -base64 32)'   ← single-quoted = literal = placeholder
# Right:  SESSION_SECRET="<paste 32+ char random string here>"
SESSION_SECRET=<generate-via-openssl-rand>

# === OPTIONAL (sensible defaults) ===

# OpenAI model to use (gpt-4o-mini = cheap, gpt-4o = better quality)
OPENAI_MODEL=gpt-4o-mini

# SQLite DB file path (relative to app root) — legacy var, kept for back-compat
DB_PATH=./data/tutorials.db

# Drizzle / better-sqlite3 connection URL. Default points at the same SQLite
# file as DB_PATH; override if you want a separate runtime DB.
DATABASE_URL=file:./data/tutorials.db

# Cost cap per parse (USD); if estimated cost exceeds, abort + report to user.
# Default 1.00 = $1 per PDF parse cap (gpt-4o-mini can do ~500 pages for ~$0.50).
COST_CAP_USD=1.00

# === REQUIRED for Phase 5 UAT (s3:// URL fetch) ===
# Updated 2026-05-22: test fixture uses s3:// schema (not presigned https://),
# so backend SDK needs real AWS credentials to fetch from the user's bucket.
#
# Lazy validation: these are NOT required at boot. They're validated the
# FIRST time an s3:// ingest is attempted, via src/lib/env.ts → s3Env().
# This lets Phase 2-4 dev/test work proceed without AWS creds in scope.
#
# Test fixture used in Phase 5:
#   s3://textbooks-561764227438-us-east-1-an/Designing Data Intensive Applications - Martin Kleppmann.pdf

# AWS_ACCESS_KEY_ID=<your-aws-access-key>
# AWS_SECRET_ACCESS_KEY=<your-aws-secret>
# AWS_REGION=us-east-1                  # default if unset; override per bucket region
