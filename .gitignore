test-results/
**/*-actual.png
**/*-diff.png

# OS noise
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Structured-event logs from src/lib/log.ts (per-day JSONL files).
# Personal-use observability — never committed; cron-prune older than 30d
# if disk pressure becomes an issue.
logs/

# Eval harness run artifacts (per docs/eval/HARNESS-DESIGN.md §D4)
_ab-runs/
_ux-walks/
