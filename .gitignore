# Environment + secrets
.env
.env.local
.env.*.local
.env.bak-*
*.pem
*.key

# Node
node_modules/
.next/
.cache/
out/
build/
dist/
.turbo/
*.tsbuildinfo

# SQLite databases (user data)
data/
*.db
*.db-journal
*.db-wal
*.db-shm

# Generated tutorials (cached LLM output)
.tutorials-cache/

# Playwright runtime artifacts (baseline PNGs in tests/playwright/*-snapshots/
